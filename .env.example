# En VPS con Caddy delante, escucha solo en localhost.
HOST=127.0.0.1
PORT=8787

# codex = usa Codex CLI autenticado en la máquina.
# openai = usa OPENAI_API_KEY.
# fallback = solo lógica local básica para pruebas sin IA.
AI_PROVIDER=codex
CODEX_BIN=/usr/local/bin/codex
ALLOW_AI_FALLBACK=false

# Opcional: etiqueta visible en /healthz para saber qué versión está corriendo.
# Si se deja vacío, la app intenta usar el commit corto de Git.
APP_VERSION=

# Opcional para micrófono/transcripción. Si están en PATH, no hace falta tocarlos.
WHISPER_BIN=/usr/local/bin/whisper
FFMPEG_BIN=/usr/bin/ffmpeg

# Obligatorio en producción para proteger CRM interno, exportaciones y endpoints de operación.
ADMIN_USER=admin
ADMIN_PASSWORD=change-me

# Opcional: envía eventos clave a Make, n8n, Zapier, Airtable, HubSpot, etc.
# Se dispara en email capturado, informe generado, interés CTA y feedback.
CRM_WEBHOOK_URL=
CRM_WEBHOOK_SECRET=
CRM_WEBHOOK_TIMEOUT=5

# Límites básicos para beta pública.
MAX_PUBLIC_EVENTS_PER_HOUR=80
MAX_MESSAGE_CHARS=3500
MAX_USER_TURNS=14
MAX_BODY_BYTES=1200000
MAX_AI_CONCURRENCY=1
AI_QUEUE_WAIT_SECONDS=8
BETA_NOINDEX=true

# Solo si usas AI_PROVIDER=openai.
OPENAI_MODEL=gpt-4.1-mini
OPENAI_API_KEY=
